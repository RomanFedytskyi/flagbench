# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# In CI/CD: inject these as encrypted secrets (GitHub Secrets, AWS Secrets Manager, etc.)

# Required: GraphQL endpoint for your flag service
GRAPHQL_URL=https://your-api.example.com/graphql

# Required: Bearer token for Authorization header
# In production: use a short-lived JWT or a secrets manager reference
GRAPHQL_TOKEN=your-token-here

# Optional: request timeout in seconds (default: 5)
GRAPHQL_TIMEOUT_S=5

# Optional: max retries on transient network errors (default: 3)
FLAGBENCH_RETRY_MAX=3

# Optional: circuit breaker failure threshold (default: 5)
# After this many consecutive failures, all resolutions return fallback_version
FLAGBENCH_CB_THRESH=5

# For local development only — starts the mock server
FLAGSERVER_TOKEN=dev-token-change-in-prod
PORT=4000
